      <div style="display:flex;gap:16px;align-items:center;flex-wrap:wrap;">
        <div class="pct-legend">
          <span><span class="legend-dot" style="background:#dbeafe;border:1px solid #93c5fd;"></span>Sales</span>
          <span><span class="legend-dot" style="background:#fef3c7;border:1px solid #fcd34d;"></span>MA3</span>
          <span><span class="legend-dot" style="background:#ffedd5;border:1px solid #fb923c;"></span>MA7</span>
          <span><span class="legend-dot" style="background:#ede9fe;border:1px solid #c4b5fd;"></span>MA14</span>
          <span style="color:#059669;font-weight:700;">▲ up</span>
          <span style="color:#dc2626;font-weight:700;">▼ down</span>
        </div>
        <div class="page-btns" id="pageBtns"></div>
      </div>
    </div>
    <div id="tableWrap"></div>
  </div>
</div>

