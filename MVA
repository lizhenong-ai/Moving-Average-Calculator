function maCalc(vals,w){
  return vals.map((_,i)=>{
    if(i<w-1)return null;
    const s=vals.slice(i-w+1,i+1);
    return s.some(v=>v===null)?null:s.reduce((a,b)=>a+b,0)/w;
  });
}
function maChg(arr){
  return arr.map((v,i)=>{
    if(v==null)return null;
    let p=null;for(let j=i-1;j>=0;j--){if(arr[j]!=null){p=arr[j];break;}}
    return p==null?null:((v-p)/p)*100;
  });
}
function lastVal(arr){return[...arr].reverse().find(v=>v!=null)??null;}
function fmtS(v){return v==null?'—':'$'+v.toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0});}
function fmtD(v){return v==null?'—':'$'+v.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});}
function pctHtml(p){
  if(p==null)return'<span class="null-cell">—</span>';
  const c=p>0.5?'pct-up':p<-0.5?'pct-down':'pct-flat';
  return`<span class="pct ${c}">${p>0.5?'▲':p<-0.5?'▼':'→'} ${Math.abs(p).toFixed(1)}%</span>`;
}
function sortIcon(col){
  if(sortCol!==col)return'<span style="opacity:0.35;margin-left:3px;">⇅</span>';
  return sortDir==='desc'?'<span style="color:#2563eb;margin-left:3px;">▼</span>':'<span style="color:#2563eb;margin-left:3px;">▲</span>';
}
