    <label>Show MA Lines</label>
    <div class="ma-toggle">
      <button class="ma-btn active-3"  data-w="3"  onclick="toggleMA(3)">MA 3</button>
      <button class="ma-btn active-7"  data-w="7"  onclick="toggleMA(7)">MA 7</button>
      <button class="ma-btn active-14" data-w="14" onclick="toggleMA(14)">MA 14</button>
    </div>
  </div>
  <div class="ctrl-group">
    <label>Previous Days</label>
    <button class="collapse-btn" id="collapseBtn" onclick="toggleCollapse()">
      <span id="collapseBtnText">Collapse Previous Days</span>
    </button>
  </div>
  <div class="ctrl-group">
    <label>Highlight Product (chart)</label>
    <div class="prod-search-wrap" id="prodSearchWrap">
      <span class="search-icon">🔍</span>
      <input class="prod-search-input" id="prodSearchInput" type="text"
        placeholder="Type to search all 1,002 products…" autocomplete="off"
        oninput="filterProdDD()" onfocus="openProdDD()">
      <div class="prod-dropdown" id="prodDropdown"></div>
    </div>
  </div>
</div>

<div class="main">
  <div class="top-bar">
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input class="search-input" type="text" id="searchBox" placeholder="Filter table by product name or category…">
    </div>
    <div class="category-pills" id="categoryPills"></div>
  </div>

  <div id="statsRow" class="stats-row" style="display:none;"></div>
  <div id="chartCard" class="chart-card" style="display:none;">
