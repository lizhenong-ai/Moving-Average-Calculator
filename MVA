  document.getElementById('statsRow').style.display='grid';
  document.getElementById('statsRow').innerHTML=`
    <div class="stat-card"><div class="label">Product</div><div class="value" style="font-size:0.95rem;">${p.name}</div><div class="sub">${p.category}</div></div>
    <div class="stat-card"><div class="label">Total</div><div class="value">${fmtS(total)}</div></div>
    <div class="stat-card"><div class="label">Daily Avg</div><div class="value">${fmtS(avg)}</div></div>
    <div class="stat-card"><div class="label">Peak Day</div><div class="value">Day ${peakDay}</div><div class="sub">${fmtS(peak)}</div></div>
    ${maCards}`;
  document.getElementById('chartCard').style.display='block';
  document.getElementById('chartTitle').textContent=p.name+' — Daily Sales with MA3 / MA7 / MA14';
  const ds=[{type:'bar',label:'Daily Sales',data:vals,backgroundColor:'rgba(37,99,235,0.2)',borderColor:'rgba(37,99,235,0.6)',borderWidth:1,borderRadius:3,order:4}];
  MA_WIN.forEach((w,wi)=>{
    const d=w===3?m3:w===7?m7:m14;
    ds.push({type:'line',label:w+'-Day MA',data:d,borderColor:MA_COLORS[w],backgroundColor:'transparent',borderWidth:2.5,pointRadius:3,pointBackgroundColor:MA_COLORS[w],tension:0.3,spanGaps:false,hidden:!activeMA.has(w),order:wi+1});
  });
  const ctx=document.getElementById('mainChart').getContext('2d');
  if(chart)chart.destroy();
  chart=new Chart(ctx,{
    data:{labels:DAYS.map(d=>'Day '+d),datasets:ds},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
      plugins:{legend:{labels:{color:'#475569',font:{size:12},boxWidth:14}},tooltip:{backgroundColor:'#fff',borderColor:'#e2e8f0',borderWidth:1,titleColor:'#1e293b',bodyColor:'#475569',callbacks:{label:c=>' '+c.dataset.label+': '+(c.raw==null?'—':'$'+c.raw.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}))}}},
      scales:{x:{ticks:{color:'#64748b'},grid:{color:'#f1f5f9'}},y:{ticks:{color:'#64748b',callback:v=>'$'+v.toLocaleString()},grid:{color:'#f1f5f9'}}}
    }
  });
}

function render(){
  const DAYS=Array.from({length:NUM_DAYS},(_,i)=>i+1);
  const lastDayIdx=NUM_DAYS-1;
  const list=filtered();
  const total=list.length,pages=Math.max(1,Math.ceil(total/PAGE_SIZE));
  if(currentPage>pages)currentPage=pages;
  const slice=list.slice((currentPage-1)*PAGE_SIZE,currentPage*PAGE_SIZE);
  if(!slice.length){document.getElementById('tableWrap').innerHTML='<div class="empty">No products match.</div>';document.getElementById('pageBtns').innerHTML='';return;}
  const sth='cursor:pointer;user-select:none;';
  let gRow=`<th rowspan="2" style="width:36px;">#</th>
    <th rowspan="2" class="sortable" style="${sth}" onclick="setSort('name')">Product${sortIcon('name')}</th>
    <th rowspan="2">Category</th>
    <th rowspan="2" class="sortable col-sales-th" style="${sth};text-align:right;border-left:2px solid #bfdbfe;" onclick="setSort('total')">Total Revenue${sortIcon('total')}</th>`;
  let sRow='';
  DAYS.forEach((d,i)=>{
    const isLatest=i===lastDayIdx;
    const isExpanded=isLatest||expandedDays.has(i);
    let maCount=0;MA_WIN.forEach(w=>{if(activeMA.has(w))maCount+=2;});
    const totalCols=1+maCount;
    if(!isExpanded){
      gRow+=`<th rowspan="2" class="day-expand-th" onclick="toggleDay(${i})" title="Expand Day ${d}">Day ${d}</th>`;
    } else {
      const lbl=isLatest?`Day ${d} (Latest)`:`Day ${d}`;
      const clk=isLatest?'':`onclick="toggleDay(${i})" style="cursor:pointer;" title="Collapse"`;
      gRow+=`<th class="group-head" colspan="${totalCols}" style="border-left:2px solid #e2e8f0;" ${clk}>${lbl}</th>`;
      sRow+=`<th class="col-sales-th" style="border-left:2px solid #bfdbfe;text-align:right;">Sales ($)</th>`;
      if(activeMA.has(3))  sRow+=`<th class="col-ma3-th" style="text-align:right;">MA3 ($)</th><th class="col-ma3-th sortable" style="${sth}" onclick="setSort('pct3_${i}')">MA3 (%)${sortIcon('pct3_'+i)}</th>`;
      if(activeMA.has(7))  sRow+=`<th class="col-ma7-th" style="text-align:right;">MA7 ($)</th><th class="col-ma7-th sortable" style="${sth}" onclick="setSort('pct7_${i}')">MA7 (%)${sortIcon('pct7_'+i)}</th>`;
      if(activeMA.has(14)) sRow+=`<th class="col-ma14-th" style="text-align:right;">MA14 ($)</th><th class="col-ma14-th sortable" style="${sth}" onclick="setSort('pct14_${i}')">MA14 (%)${sortIcon('pct14_'+i)}</th>`;
    }
  });
  const rows=slice.map((p,idx)=>{
    const rank=(currentPage-1)*PAGE_SIZE+idx+1;
    const m3=maCalc(p.values,3),m7=maCalc(p.values,7),m14=maCalc(p.values,14);
    const p3=maChg(m3),p7=maChg(m7),p14=maChg(m14);
    const total15=RANK_MAP[p.name]?.total;
    let cells='';
    DAYS.forEach((d,i)=>{
      const isLatest=i===lastDayIdx;
      const isExpanded=isLatest||expandedDays.has(i);
      const v=p.values[i];
      if(!isExpanded){
        cells+=`<td style="text-align:center;color:#cbd5e1;font-size:0.65rem;border-left:1px solid #f1f5f9;">·</td>`;
      } else {
        cells+=`<td class="col-sales" style="border-left:2px solid #bfdbfe;">${v==null?'<span class="null-cell">—</span>':fmtD(v)}</td>`;
        if(activeMA.has(3))  cells+=`<td class="col-ma3 ${m3[i]==null?'null-cell':''}">${m3[i]==null?'—':fmtD(m3[i])}</td><td class="col-ma3">${pctHtml(p3[i])}</td>`;
        if(activeMA.has(7))  cells+=`<td class="col-ma7 ${m7[i]==null?'null-cell':''}">${m7[i]==null?'—':fmtD(m7[i])}</td><td class="col-ma7">${pctHtml(p7[i])}</td>`;
        if(activeMA.has(14)) cells+=`<td class="col-ma14 ${m14[i]==null?'null-cell':''}">${m14[i]==null?'—':fmtD(m14[i])}</td><td class="col-ma14">${pctHtml(p14[i])}</td>`;
      }
    });
    return`<tr>
      <td style="color:#94a3b8;font-size:0.75rem;text-align:center;font-weight:600;">${rank}</td>
      <td style="font-weight:600;color:#1e293b;">${p.name}</td>
      <td style="color:#64748b;font-size:0.75rem;">${p.category}</td>
      <td class="col-sales" style="border-left:2px solid #bfdbfe;">${total15!=null?fmtD(total15):'—'}</td>
      ${cells}
    </tr>`;
  }).join('');
  document.getElementById('tableWrap').innerHTML=`<div style="overflow-x:auto;"><table><thead><tr>${gRow}</tr><tr>${sRow}</tr></thead><tbody>${rows}</tbody></table></div>`;
  const pb=document.getElementById('pageBtns');
  if(pages<=1){pb.innerHTML=`<span class="page-info">${total} products</span>`;return;}
  let btns=`<span class="page-info">${total} products · Page ${currentPage}/${pages}</span>`;
  if(currentPage>1)btns+=`<button class="page-btn" onclick="goPage(${currentPage-1})">‹</button>`;
  const s=Math.max(1,currentPage-2),e=Math.min(pages,currentPage+2);
  for(let i=s;i<=e;i++)btns+=`<button class="page-btn${i===currentPage?' active':''}" onclick="goPage(${i})">${i}</button>`;
  if(currentPage<pages)btns+=`<button class="page-btn" onclick="goPage(${currentPage+1})">›</button>`;
  pb.innerHTML=btns;
}

function goPage(n){const sx=getScrollX();currentPage=n;render();setScrollX(sx);}

render();
</script>
</body>
</html>
