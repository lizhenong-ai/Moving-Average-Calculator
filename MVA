function openProdDD(){filterProdDD();document.getElementById('prodDropdown').classList.add('open');}
function filterProdDD(){
  const q=document.getElementById('prodSearchInput').value.toLowerCase().trim();
  const dd=document.getElementById('prodDropdown');
  const matches=RAW.map((p,i)=>{return{...p,_i:i}}).filter(p=>!q||p.name.toLowerCase().includes(q)||p.category.toLowerCase().includes(q));
  const shown=matches.slice(0,60);
  if(!shown.length){ dd.innerHTML='<div class="pd-empty">No products found</div>'; }
  else {
    const cls=c=>CAT_CLS[c]||'cat-default';
    dd.innerHTML=`<div class="pd-header">Showing ${shown.length} of ${matches.length} — type to filter</div>`+
      shown.map(p=>`<div class="pd-item${p._i===selIdx?' selected':''}" onmousedown="selectProd(${p._i})">
