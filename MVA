<title>Moving Average Calculator</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f0f4f8; color: #1e293b; min-height: 100vh; }

  header {
    background: #fff; padding: 18px 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
    border-bottom: 2px solid #e2e8f0;
  }
  header h1 { font-size: 1.3rem; font-weight: 700; color: #1e293b; }
  header span { font-size: 0.8rem; color: #94a3b8; }

  .controls {
    background: #fff; padding: 16px 32px; border-bottom: 2px solid #e2e8f0;
    display: flex; flex-wrap: wrap; gap: 20px; align-items: flex-end;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  .ctrl-group { display: flex; flex-direction: column; gap: 5px; }
  .ctrl-group label { font-size: 0.72rem; color: #64748b; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }

  .ma-toggle { display: flex; gap: 8px; }
  .ma-btn {
    padding: 6px 16px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; cursor: pointer;
    border: 2px solid #cbd5e1; background: #f8fafc; color: #64748b; transition: all 0.15s;
  }
  .ma-btn:hover { border-color: #94a3b8; color: #334155; }
  .ma-btn.active-3  { background: #fde68a; border-color: #b45309; color: #78350f; }
  .ma-btn.active-7  { background: #fed7aa; border-color: #c2410c; color: #7c2d12; }
  .ma-btn.active-14 { background: #ddd6fe; border-color: #6d28d9; color: #3b0764; }

  .collapse-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 8px; font-size: 0.82rem; font-weight: 600; cursor: pointer;
    border: 2px solid #cbd5e1; background: #f8fafc; color: #475569; transition: all 0.15s;
  }
  .collapse-btn:hover { border-color: #2563eb; color: #1d4ed8; background: #eff6ff; }
  .collapse-btn.collapsed { border-color: #2563eb; background: #dbeafe; color: #1e40af; }

  .prod-search-wrap { position: relative; }
  .prod-search-wrap .search-icon {
    position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; pointer-events: none; font-size: 14px;
  }
  .prod-search-input {
    background: #f8fafc; color: #1e293b; border: 2px solid #cbd5e1;
    border-radius: 10px; padding: 8px 12px 8px 34px; font-size: 0.88rem; outline: none;
    width: 260px; transition: border-color 0.15s, box-shadow 0.15s;
  }
  .prod-search-input:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.12); background: #fff; }
  .prod-search-input::placeholder { color: #94a3b8; }
  .prod-dropdown {
    position: absolute; top: calc(100% + 6px); left: 0; width: 320px;
    background: #fff; border: 2px solid #cbd5e1; border-radius: 12px;
    max-height: 320px; overflow-y: auto; z-index: 200;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12); display: none;
  }
  .prod-dropdown.open { display: block; }
  .pd-header {
    padding: 8px 14px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; color: #94a3b8; border-bottom: 1px solid #f1f5f9; background: #f8fafc;
    border-radius: 10px 10px 0 0; position: sticky; top: 0;
  }
  .pd-item {
    padding: 10px 14px; cursor: pointer; font-size: 0.85rem;
    border-bottom: 1px solid #f1f5f9; transition: background 0.1s;
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
  }
  .pd-item:last-child { border-bottom: none; }
  .pd-item:hover { background: #eff6ff; }
  .pd-item.selected { background: #dbeafe; }
  .pd-item .pd-name { font-weight: 600; color: #1e293b; }
  .pd-item.selected .pd-name { color: #1d4ed8; }
  .pd-item .pd-cat {
    font-size: 0.7rem; color: #fff; padding: 2px 7px; border-radius: 10px;
    font-weight: 600; white-space: nowrap; flex-shrink: 0;
  }
  .pd-empty { padding: 16px 14px; color: #94a3b8; font-size: 0.85rem; text-align: center; }
  .pd-count { padding: 8px 14px; font-size: 0.7rem; color: #94a3b8; text-align: center; border-top: 1px solid #f1f5f9; background: #f8fafc; border-radius: 0 0 10px 10px; }

  .cat-games    { background: #6366f1; }
  .cat-gift     { background: #f59e0b; }
  .cat-payment  { background: #10b981; }
  .cat-software { background: #ef4444; }
  .cat-telco    { background: #8b5cf6; }
  .cat-default  { background: #64748b; }

  .main { padding: 20px 32px; display: flex; flex-direction: column; gap: 20px; }

  .top-bar { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
  .search-wrap { position: relative; }
  .search-wrap .search-icon {
    position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; pointer-events: none; font-size: 14px;
  }
  .search-input {
    background: #f8fafc; color: #1e293b; border: 2px solid #cbd5e1;
    border-radius: 10px; padding: 8px 12px 8px 34px; font-size: 0.88rem; outline: none;
    width: 260px; transition: border-color 0.15s, box-shadow 0.15s;
  }
  .search-input:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.12); background: #fff; }
  .search-input::placeholder { color: #94a3b8; }
  .category-pills { display: flex; flex-wrap: wrap; gap: 8px; }
  .pill {
    padding: 5px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; cursor: pointer;
    border: 2px solid #e2e8f0; background: #fff; color: #475569; transition: all 0.15s;
  }
  .pill:hover { border-color: #93c5fd; color: #1d4ed8; background: #eff6ff; }
  .pill.active { background: #2563eb; border-color: #2563eb; color: #fff; }

  .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; }
  .stat-card {
    background: #fff; border: 2px solid #e2e8f0; border-radius: 12px; padding: 14px 18px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }
  .stat-card .label { font-size: 0.68rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; font-weight: 700; }
  .stat-card .value { font-size: 1.3rem; font-weight: 800; color: #1e293b; }
  .stat-card .sub   { font-size: 0.72rem; color: #64748b; margin-top: 3px; }
  .stat-card.c3  { border-color: #d97706; background: #fffbeb; }
  .stat-card.c3 .value  { color: #92400e; }
  .stat-card.c7  { border-color: #ea580c; background: #fff7ed; }
  .stat-card.c7 .value  { color: #7c2d12; }
  .stat-card.c14 { border-color: #7c3aed; background: #f5f3ff; }
  .stat-card.c14 .value { color: #4c1d95; }

  .chart-card {
    background: #fff; border: 2px solid #e2e8f0; border-radius: 12px; padding: 20px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }
  .chart-card h2 { font-size: 0.9rem; color: #475569; margin-bottom: 14px; font-weight: 700; }
  .chart-wrapper { position: relative; height: 320px; }

  .table-card {
    background: #fff; border: 2px solid #e2e8f0; border-radius: 12px; overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }
  .table-header {
    padding: 14px 20px; border-bottom: 2px solid #e2e8f0;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    background: #f8fafc;
  }
  .table-header h2 { font-size: 0.9rem; color: #334155; font-weight: 700; }

  table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  th {
    background: #f1f5f9; color: #475569; font-weight: 700;
    padding: 9px 10px; font-size: 0.68rem; text-transform: uppercase;
    letter-spacing: 0.04em; white-space: nowrap; border-bottom: 2px solid #e2e8f0;
  }
  th.group-head { text-align: center; font-size: 0.72rem; color: #334155; }
  th.sortable { cursor: pointer; user-select: none; }
  th.sortable:hover { color: #1d4ed8; background: #e0f2fe; }
  td { padding: 7px 10px; border-top: 1px solid #f1f5f9; white-space: nowrap; color: #334155; }
  tr:hover td { background: #f8fafc !important; }

  th.col-sales-th { background: #dbeafe !important; color: #1e40af !important; border-bottom: 2px solid #93c5fd; }
  td.col-sales    { background: #eff6ff; color: #1e40af; font-weight: 600; text-align: right; border-left: 2px solid #bfdbfe; }
  tr:hover td.col-sales { background: #dbeafe !important; }

  th.col-ma3-th { background: #fef3c7 !important; color: #92400e !important; border-bottom: 2px solid #fcd34d; }
  td.col-ma3    { background: #fffbeb; color: #92400e; font-weight: 600; text-align: right; }
  tr:hover td.col-ma3 { background: #fef3c7 !important; }

  th.col-ma7-th { background: #ffedd5 !important; color: #7c2d12 !important; border-bottom: 2px solid #fb923c; }
  td.col-ma7    { background: #fff7ed; color: #7c2d12; font-weight: 600; text-align: right; }
  tr:hover td.col-ma7 { background: #ffedd5 !important; }

  th.col-ma14-th { background: #ede9fe !important; color: #4c1d95 !important; border-bottom: 2px solid #c4b5fd; }
  td.col-ma14    { background: #f5f3ff; color: #4c1d95; font-weight: 600; text-align: right; }
  tr:hover td.col-ma14 { background: #ede9fe !important; }

  .null-cell { color: #cbd5e1 !important; font-weight: 400 !important; }

  .day-expand-th {
    cursor: pointer; text-align: center; padding: 6px 8px; font-size: 0.68rem;
    background: #f1f5f9; color: #94a3b8; border-left: 2px solid #e2e8f0; white-space: nowrap;
  }
  .day-expand-th:hover { color: #2563eb; background: #dbeafe; }

  .pct { font-size: 0.72rem; font-weight: 700; }
  .pct-up   { color: #059669; }
  .pct-down { color: #dc2626; }
  .pct-flat { color: #94a3b8; }

  .page-btns { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
  .page-btn {
    background: #fff; border: 2px solid #e2e8f0; color: #475569;
    padding: 4px 11px; border-radius: 6px; cursor: pointer; font-size: 0.78rem; font-weight: 600; transition: all 0.12s;
  }
  .page-btn:hover { border-color: #2563eb; color: #1d4ed8; background: #eff6ff; }
  .page-btn.active { background: #2563eb; border-color: #2563eb; color: #fff; }
  .page-info { font-size: 0.78rem; color: #64748b; }

  .legend-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 4px; }
  .pct-legend { font-size: 0.75rem; color: #64748b; display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .empty { padding: 40px; text-align: center; color: #94a3b8; font-size: 0.9rem; }
</style>
</head>
