function filtered(){
  let list=RAW.filter(p=>(selectedCat==='All'||p.category===selectedCat)&&(!searchTerm||p.name.toLowerCase().includes(searchTerm)||p.category.toLowerCase().includes(searchTerm)));
  const dir=sortDir==='desc'?-1:1;
  if(sortCol==='name') list.sort((a,b)=>dir*a.name.localeCompare(b.name));
  else if(sortCol==='total') list.sort((a,b)=>dir*((RANK_MAP[b.name]?.total??0)-(RANK_MAP[a.name]?.total??0)));
  else {
    const parts=sortCol.split('_');
    const w=parts[0]==='pct3'?3:parts[0]==='pct7'?7:14;
    const dayIdx=parseInt(parts[1]);
    list.sort((a,b)=>{
      const pa=maChg(maCalc(a.values,w))[dayIdx]??-Infinity;
      const pb=maChg(maCalc(b.values,w))[dayIdx]??-Infinity;
      return dir*(pb-pa);
    });
  }
  return list;
}

function renderChart(idx){
  const p=RAW[idx],vals=p.values;
